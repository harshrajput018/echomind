# ── MongoDB Atlas ─────────────────────────────────
# Paste your Atlas connection string here (step 4 of setup guide)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/echomind?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────
JWT_SECRET=make_this_a_long_random_string_123abc
JWT_EXPIRES_IN=7d

# ── Groq (FREE) ───────────────────────────────────
# Get free API key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Server ────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── File Upload ───────────────────────────────────
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=./uploads
